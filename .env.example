# ========== SERVER ==========
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
CLIENT_URL=http://localhost:3000

# ========== DATABASE ==========
MONGO_URI=mongodb://localhost:27017/saree_showroom

# ========== JWT ==========
JWT_ACCESS_SECRET=replace_with_long_random_string_32_chars_min_xxxxxxxxx
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_another_long_random_string_xxxxxxxxxxxx
JWT_REFRESH_EXPIRES_IN=30d
JWT_RESET_SECRET=replace_with_yet_another_string_xxxxxxxxxxxxxxxxxxxxxx
JWT_RESET_EXPIRES_IN=15m

# ========== EMAIL ==========
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="Saree Showroom <no-reply@yourdomain.com>"

# ========== CLOUDINARY ==========
CLOUDINARY_CLOUD_NAME=your_cloud
CLOUDINARY_API_KEY=your_key
CLOUDINARY_API_SECRET=your_secret
CLOUDINARY_FOLDER=saree_showroom

# ========== RAZORPAY ==========
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=your_secret
RAZORPAY_WEBHOOK_SECRET=whsec_xxx

# ========== OTP (MSG91 / Twilio) ==========
# Leave empty in dev — OTP is logged to console for testing
OTP_PROVIDER=console
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_TEMPLATE_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ========== GOOGLE SHEET SYNC ==========
# Master sheet "published as CSV" link (File → Share → Publish to web → CSV)
GOOGLE_SHEET_CSV_URL=
# Cron: every 5 minutes by default
SYNC_CRON="*/5 * * * *"
SYNC_ENABLED=false

# ========== RATE LIMIT ==========
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ========== LOGGING ==========
LOG_LEVEL=info
